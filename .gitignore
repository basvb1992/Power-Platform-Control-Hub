# Logs
logs
*.log
npm-debug.log*

# Dependencies
node_modules/
dist/

# Local env files — copy .env.example and fill in your values
.env
.env.local
.env.*.local

# Power Apps config — generated by `npx power-apps init`
power.config.json
# Backup of power.config.json — also contains environment/connection IDs, do not commit
power.config.backup.json
power.config.*.backup.json

# Generated connector service files — regenerate with `npx power-apps add-data-source`
# src/generated/ is committed since Dataverse-table files (Aaduser, Bots, Ppa_resourcetombstones)
# require --resource-name flags and are not regenerated by a plain add-data-source run.
# power.config.json (which contains connection IDs) is still gitignored above.

# Deploy environment config — contains connection IDs, do not commit
deploy/env-config.json

